+/**
+ * @file
+ * Styles for the slider component.
+ */
+
+@import "../../../../../../../../vendor/twbs/bootstrap/scss/functions";
+
+// Default variable overrides
+@import "../../../../../../../themes/custom/childtheme/scss/variables";
+@import "../../../../../../../../vendor/twbs/bootstrap/scss/variables";
+@import "../../../../../../../../vendor/twbs/bootstrap/scss/maps";
+@import "../../../../../../../../vendor/twbs/bootstrap/scss/mixins";
+@import "../../../../../../../themes/custom/childtheme/scss/mixins";
+@import "../../../../../../../themes/custom/childtheme/scss/functions";
+
+.slider-component {
+  --swiper-pagination-bottom: 0;
+  position: relative;
+  width: 100%;
+  overflow: hidden;
+  @include media-breakpoint-down(lg) {
+    .swiper-button-prev,
+    .swiper-button-next {
+      display: none;
+    }
+  }
+  .swiper-slide {
+    > * {
+      width: 100%;
+    }
+  }
+  &.swiper-inactive {
+    .swiper-button-prev,
+    .swiper-button-next {
+      display: none;
+    }
+    .swiper-pagination {
+      display: none;
+    }
+  }
+  &:not(.swiper-inactive) {
+    --pd-slider-nav-padding: 0;
+    @include media-breakpoint-up(lg) {
+      --pd-slider-nav-padding: 4.5rem;
+    }
+    padding: 0 var(--pd-slider-nav-padding, 0) 2.5rem;
+    .swiper-slide {
+      /* Need to make swipe event working for iframes inside */
+      &::after {
+        content: "";
+        background: transparent;
+        width: 100%;
+        height: 100%;
+        min-height: 1px;
+        position: absolute;
+        top: 0;
+        left: 0;
+        z-index: 9;
+        clip-path: polygon(0 15%, 100% 15%, 100% 90%, 0 90%, 0 15%, 42% 25%, 42% 61%, 59% 61%, 59% 45%, 25% 45%);
+      }
+    }
+    .swiper-button {
+      top: 0;
+      width: var(--pd-slider-nav-padding, 4.5rem);
+      height: calc(100% - 2.5rem);
+      margin-top: 0;
+      opacity: 1;
+      background-color: var(--bs-body-bg);
+      &:before {
+        content: "";
+        position: absolute;
+        width: 3rem;
+        height: 3rem;
+        transition: all .15s ease-in-out;
+        background-color: var(--pd-slider-btn-color, var(--bs-primary));
+        border-radius: .5rem;
+      }
+      &:after {
+        position: absolute;
+        top: 50%;
+        right: 0;
+        width: 3rem;
+        height: 2rem;
+        content: "";
+        transition: all .15s ease-in-out;
+        mask-repeat: no-repeat;
+        mask-position: center;
+        mask-size: 1.75rem;
+        translate: .0625rem -50%;
+        background-color: var(--pd-slider-bg-color, #{$gray-900});
+      }
+      &-prev {
+        &,
+        &:before,
+        &:after {
+          left: 0;
+        }
+        &:after {
+          mask-image: url(/themes/custom/childtheme/img/icons/chevron-left.svg);
+        }
+      }
+      &-next {
+        &,
+        &:before,
+        &:after {
+          right: 0;
+        }
+        &:after {
+          mask-image: url(/themes/custom/childtheme/img/icons/chevron-right.svg);
+        }
+      }
+    }
+  }
+  .swiper-pagination {
+    display: flex;
+    justify-content: center;
+    margin-top: px-to-rem(20px);
+    padding-top: #{$carousel-indicator-hit-area-height};
+    padding-bottom: #{$carousel-indicator-hit-area-height};
+    .swiper-pagination-bullet {
+      position: relative;
+      width: var(--pd-indicator-width, #{$carousel-indicator-width});
+      height: var(--pd-indicator-height, #{$carousel-indicator-height});
+      margin-right: var(--pd-carousel-indicator-spacer, #{$carousel-indicator-spacer});
+      margin-left: var(--pd-carousel-indicator-spacer, #{$carousel-indicator-spacer});
+      padding: 0;
+      transition: $carousel-indicator-transition;
+      opacity: $carousel-indicator-opacity;
+      border: var(--pd-indicator-border, unset);
+      border-radius: var(--pd-indicator-border-radius, .5rem);
+      background-color: var(--pd-indicator-bg, #{rgba($gray-300, .75)});
+      &:hover,
+      &:focus {
+        opacity: $carousel-indicator-active-opacity;
+      }
+      &::after {
+        position: absolute;
+        top: 50%;
+        left: 50%;
+        display: block;
+        width: calc(var(--pd-indicator-width, #{$carousel-indicator-width}) + (2 * var(--pd-carousel-indicator-spacer, #{$carousel-indicator-spacer})));
+        height: calc(var(--pd-indicator-height, #{$carousel-indicator-height}) + (2 * #{$carousel-indicator-hit-area-height}));
+        content: "";
+        transform: translate(-50%, -50%);
+      }
+      &.swiper-pagination-bullet-active {
+        --pd-indicator-bg: var(--pd-indicator-active-bg, #{$carousel-indicator-active-bg});
+        opacity: $carousel-indicator-active-opacity;
+      }
+    }
+  }
+}
diff --git a/modules/sc_swiper/components/slider/slider.twig b/modules/sc_swiper/components/slider/slider.twig
new file mode 100644
index 0000000..d032912
--- /dev/null
+++ b/modules/sc_swiper/components/slider/slider.twig
@@ -0,0 +1,86 @@
+{#
+/**
+ * @file
+ * Slider component using Swiper.
+ *
+ * Available variables:
+ * - items: Array of items to display in the slider.
+ * - loop: Enable continuous loop mode.
+ * - speed: Duration of transition between slides (in ms).
+ * - autoplay: Enable autoplay.
+ * - breakpointMobile: Breakpoint for mobile devices.
+ * - itemsMobile: Number of slides per view on mobile.
+ * - breakpointTablet: Breakpoint for tablet devices.
+ * - itemsTablet: Number of slides per view on tablet.
+ * - breakpointDesktop: Breakpoint for desktop devices.
+ * - itemsDesktop: Number of slides per view on desktop.
+ * - navigation: Show navigation buttons.
+ * - delay: Delay between transitions in autoplay mode (in ms).
+ * - pauseOnMouseEnter: Pause autoplay on mouse enter.
+ * - allowTouchMove: Allow touch move.
+ * - spaceBetween: Space between slides.
+ * - pagination: Show pagination.
+ * - scrollbar: Show scrollbar.
+ * - clickablePagination: Make pagination clickable.
+ * - paginationType: Type of pagination.
+ * - spaceBetweenMobile: Space between slides on mobile.
+ * - spaceBetweenTablet: Space between slides on tablet.
+ * - spaceBetweenDesktop: Space between slides on desktop.
+ * - effect: Transition effect.
+ */
+#}
+
+{% set slider_id = 'slider-' ~ random() %}
+{% set slider_config = {
+  'loop': loop|default(TRUE),
+  'speed': speed|default(1000),
+  'autoplay': autoplay|default(FALSE),
+  'breakpointMobile': breakpointMobile|default(0),
+  'itemsMobile': itemsMobile|default(1),
+  'breakpointTablet': breakpointTablet|default(768),
+  'itemsTablet': itemsTablet|default(2),
+  'breakpointDesktop': breakpointDesktop|default(992),
+  'itemsDesktop': itemsDesktop|default(3),
+  'navigation': navigation|default(TRUE),
+  'delay': delay|default(3000),
+  'pauseOnMouseEnter': pauseOnMouseEnter|default(TRUE),
+  'allowTouchMove': allowTouchMove|default(TRUE),
+  'spaceBetween': spaceBetween|default(24),
+  'pagination': pagination|default(TRUE),
+  'scrollbar': scrollbar|default(FALSE),
+  'clickablePagination': clickablePagination|default(TRUE),
+  'paginationType': paginationType|default('bullets'),
+  'spaceBetweenMobile': spaceBetweenMobile|default(24),
+  'spaceBetweenTablet': spaceBetweenTablet|default(24),
+  'spaceBetweenDesktop': spaceBetweenDesktop|default(24),
+  'effect': effect|default('slide')
+} %}
+
+{% set title_tag = title_tag|default('h3') %}
+
+{% if attributes is empty %}
+  {% set attributes = create_attribute() %}
+{% endif %}
+
+<div {{ attributes.addClass('slider-component').setAttribute('id', slider_id).setAttribute('data-swiper', slider_config|json_encode) }}">
+  <div class="swiper-wrapper">
+    {% for item in items %}
+      <div class="swiper-slide">
+        {{ item|raw }}
+      </div>
+    {% endfor %}
+  </div>
+  
+  {% if navigation %}
+    <div class="swiper-button swiper-button-prev"></div>
+    <div class="swiper-button swiper-button-next"></div>
+  {% endif %}
+
+  {% if pagination %}
+    <div class="swiper-pagination"></div>
+  {% endif %}
+  
+  {% if scrollbar %}
+    <div class="swiper-scrollbar"></div>
+  {% endif %}
+</div>
\ No newline at end of file
