diff --git a/modules/sc_swiper/sc_swiper.post_update.php b/modules/sc_swiper/sc_swiper.post_update.php
new file mode 100755
index 0000000..2f06b80
--- /dev/null
+++ b/modules/sc_swiper/sc_swiper.post_update.php
@@ -0,0 +1,95 @@
+<?php
+
+/**
+ * @file
+ * Post update functions for Slider Collection Swiper module.
+ */
+
+use Drupal\Core\Config\Entity\ConfigEntityUpdater;
+use Drupal\Core\Entity\Display\EntityViewDisplayInterface;
+use Drupal\views\ViewEntityInterface;
+
+/**
+ * Post update to have view style configuration in the same format (camelCase).
+ */
+function sc_swiper_post_update_view_style_fields_key_update(?array &$sandbox = NULL): void {
+  \Drupal::classResolver(ConfigEntityUpdater::class)->update($sandbox, 'view', function (ViewEntityInterface $view): bool {
+    $changed = FALSE;
+    $displays = $view->get('display');
+    foreach ($displays as &$display) {
+      if (
+        isset($display['display_options']['style']) &&
+        $display['display_options']['style']['type'] === 'sc_swiper' &&
+        !empty($display['display_options']['style']['options'])
+      ) {
+        $settings = &$display['display_options']['style']['options'];
+        $changed = _sc_swiper_update_configs_to_camel_case($settings);
+      }
+    }
+
+    if ($changed) {
+      $view->set('display', $displays);
+    }
+
+    return $changed;
+  });
+}
+
+/**
+ * Post update to have swiper configuration in the same format (camelCase).
+ */
+function sc_swiper_post_update_formatter_fields_key_update(?array &$sandbox = NULL): void {
+  \Drupal::classResolver(ConfigEntityUpdater::class)
+    ->update($sandbox, 'entity_view_display', function (EntityViewDisplayInterface $display) {
+      $components = $display->getComponents();
+
+      foreach ($components as $field_name => $component) {
+        if (isset($component['type']) &&
+          in_array($component['type'], [
+            'swiper_entity_reference',
+            'swiper_entity_reference_revisions',
+          ]) &&
+          !empty($component['settings'])
+        ) {
+          $settings = &$component['settings'];
+          if (_sc_swiper_update_configs_to_camel_case($settings)) {
+            $display->setComponent($field_name, $component);
+            $changed = TRUE;
+          }
+        }
+      }
+
+      return $changed ?? FALSE;
+    });
+}
+
+/**
+ * Helper function to update Swiper settings to use camelCase keys.
+ *
+ * @param array $settings
+ *   The settings array to update.
+ *
+ * @return bool
+ *   TRUE if any changes were made, FALSE otherwise.
+ */
+function _sc_swiper_update_configs_to_camel_case(array &$settings) {
+  $mapping = [
+    'clickable_pagination' => 'clickablePagination',
+    'pagination_type' => 'paginationType',
+  ];
+  foreach ($mapping as $old_key => $new_key) {
+    if (isset($settings[$old_key])) {
+      $settings[$new_key] = $settings[$old_key];
+      unset($settings[$old_key]);
+      $changed = TRUE;
+    }
+  }
+
+  // Convert empty string values to NULL for effect property.
+  if ($settings['effect'] === '') {
+    $settings['effect'] = 'slide';
+    $changed = TRUE;
+  }
+
+  return $changed ?? FALSE;
+}
