+      default: true
+    pagination:
+      type: boolean
+      title: Pagination
+      description: Show pagination
+      default: true
+    clickablePagination:
+      type: boolean
+      title: Clickable Pagination
+      description: Make pagination clickable
+      default: true
+    paginationType:
+      type: string
+      title: Pagination Type
+      description: Type of pagination
+      default: bullets
+      enum:
+        - bullets
+        - fraction
+        - progressbar
+    effect:
+      type: ['string', 'null']
+      title: Effect
+      description: Transition effect
