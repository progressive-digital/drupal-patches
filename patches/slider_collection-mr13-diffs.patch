diff --git a/modules/sc_swiper/components/slider/slider.js b/modules/sc_swiper/components/slider/slider.js
new file mode 100644
index 0000000..72a1a68
--- /dev/null
+++ b/modules/sc_swiper/components/slider/slider.js
@@ -0,0 +1,101 @@
+/**
+ * @file
+ * JavaScript for the slider component.
+ */
+(function (Drupal, once) {
+
+  'use strict';
+
+  /**
+   * Initialize the slider component.
+   *
+   * @type {Drupal~behavior}
+   */
+  Drupal.behaviors.sliderComponent = {
+    attach: function (context, settings) {
+      once('slider-component', '.slider-component', context)
+        .forEach(function (slider) {
+          // Get the slider configuration from the data attribute.
+          const config = JSON.parse(slider.getAttribute('data-swiper'));
+          // Initialize Swiper with the configuration.
+          new Swiper(slider, Drupal.behaviors.sliderComponent.prepareConfigs(slider, config));
+        });
+    },
+    prepareConfigs(slider, config) {
+      return {
+        // Core settings
+        loop: config.loop,
+        speed: config.speed,
+        spaceBetween: config.spaceBetween,
+        allowTouchMove: config.allowTouchMove,
+        effect: config.effect,
+        ...(config.effect === 'fade' ? {fadeEffect: {crossFade: true}} : {}),
+
+        // Autoplay settings
+        autoplay: config.autoplay ? {
+          delay: config.delay,
+          disableOnInteraction: false,
+          pauseOnMouseEnter: config.pauseOnMouseEnter
+        } : false,
+
+        // Navigation settings
+        navigation: config.navigation ? {
+          nextEl: slider.querySelector('.swiper-button-next'),
+          prevEl: slider.querySelector('.swiper-button-prev'),
+        } : false,
+
+        // Pagination settings
+        pagination: config.pagination ? {
+          el: slider.querySelector('.swiper-pagination'),
+          type: config.paginationType,
+          clickable: config.clickablePagination
+        } : false,
+
+        // Scrollbar settings
+        scrollbar: config.scrollbar ? {
+          el: '.swiper-scrollbar',
+          draggable: true
+        } : false,
+
+        // Responsive breakpoints
+        breakpoints: {
+          // Mobile
+          [config.breakpointMobile]: {
+            slidesPerView: config.itemsMobile,
+            spaceBetween: config.spaceBetweenMobile
+          },
+          // Tablet
+          [config.breakpointTablet]: {
+            slidesPerView: config.itemsTablet,
+            spaceBetween: config.spaceBetweenTablet
+          },
+          // Desktop
+          [config.breakpointDesktop]: {
+            slidesPerView: config.itemsDesktop,
+            spaceBetween: config.spaceBetweenDesktop
+          }
+        },
+        // Events
+        on: {
+          init: function () {
+            // Add class if there's only one slide or fewer slides than slidesPerView
+            if (this.slides.length <= this.params.slidesPerView) {
+              slider.classList.add('swiper-inactive');
+            }
+          },
+          resize: function () {
+            // Check if slider should be inactive on resize
+            slider.classList.toggle('swiper-inactive', this.slides.length <= this.params.slidesPerView);
+          },
+          slideChangeTransitionStart: function () {
+            slider.classList.add('swiper-transition');
+          },
+          slideChangeTransitionEnd: function () {
+            slider.classList.remove('swiper-transition');
+          }
+        }
+      }
+    }
+  };
+
+})(Drupal, once);
