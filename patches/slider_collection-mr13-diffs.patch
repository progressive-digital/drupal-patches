@@ -2,6 +2,7 @@
 
 namespace Drupal\sc_swiper;
 
+use Drupal\Core\Theme\ComponentPluginManager;
 use Drupal\slider_collection\SliderCollectionSliderBase;
 
 /**
@@ -9,6 +10,14 @@ use Drupal\slider_collection\SliderCollectionSliderBase;
  */
 class SwiperBase extends SliderCollectionSliderBase {
 
+  /**
+   * The component plugin manager.
+   *
+   * @var \Drupal\Core\Theme\ComponentPluginManager $componentPluginManager
+   *   The plugin manager service to deal with components.
+   */
+  public function __construct(protected ComponentPluginManager $componentPluginManager) {}
+
   /**
    * {@inheritdoc}
    */
@@ -38,9 +47,26 @@ class SwiperBase extends SliderCollectionSliderBase {
   /**
    * {@inheritdoc}
    */
-  public function formattedSettings($settings): array {
-    // If the key is not in the default settings, remove it.
-    return array_intersect_key($settings, $this->defaultSettings());
+  public function formattedSettings(array $settings): array {
+    $sdc = $this->componentPluginManager->find('sc_swiper:slider');
+    $sdc_properties = $sdc->getPluginDefinition()['props']['properties'] ?? [];
+    foreach ($settings as $key => $value) {
+      $definition = $sdc_properties[$key] ?? NULL;
+      if (!$definition || !isset($definition['type']) || is_array($definition['type'])) {
+        continue;
+      }
+
+      $settings[$key] = match ($definition['type']) {
+        'boolean' => (bool) $value,
+        'integer' => (int) $value,
+        'string' => (string) $value,
+        'float' => (float) $value,
+        'array' => !is_array($value) ? [] : $value,
+        default => $value,
+      };
+    }
+
+    return $settings;
   }
 
 }
