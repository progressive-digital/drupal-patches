+    // Get the style options from the form state.
+    $options = &$form_state->getValue('style_options');
+
+    // If the effect is not set, we set it to NULL.
+    if (empty($options['effect'])) {
+      $options['effect'] = NULL;
+    }
+  }
+
 }
