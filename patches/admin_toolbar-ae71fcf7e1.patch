From ae71fcf7e1ec821a94ca9c46b0c2b7c128313ee8 Mon Sep 17 00:00:00 2001
From: Kostia Bohach <k.bohach@dev-branch.com>
Date: Tue, 14 Oct 2025 16:25:51 +0300
Subject: [PATCH] [#3552085] feat: Use new Icon API

---
 .../admin_toolbar_tools.icons.yml             | 36 +++++++++++++++++++
 .../admin_toolbar_tools.module                | 11 ++++++
 .../assets/icons/local_tasks.svg              |  3 ++
 3 files changed, 50 insertions(+)
 create mode 100644 admin_toolbar_tools/admin_toolbar_tools.icons.yml
 create mode 100644 admin_toolbar_tools/assets/icons/local_tasks.svg

diff --git a/admin_toolbar_tools/admin_toolbar_tools.icons.yml b/admin_toolbar_tools/admin_toolbar_tools.icons.yml
new file mode 100644
index 0000000..9e7364c
--- /dev/null
+++ b/admin_toolbar_tools/admin_toolbar_tools.icons.yml
@@ -0,0 +1,36 @@
+admin_toolbar_tools:
+  enabled: true
+  label: "Admin Toolbar Tools"
+  description: "Icons available within the Admin Toolbar Tools module."
+  version: 3.x
+  license:
+    name: GPL2-or-later
+    url: https://api.drupal.org/api/drupal/core%21LICENSE.txt/11.x
+    gpl-compatible: true
+  extractor: svg
+  config:
+    sources:
+      - assets/icons/*.svg
+  settings:
+    size:
+      title: "Size"
+      description: "Set a size for this icon."
+      type: "integer"
+      default: 20
+    class:
+      title: "Class"
+      description: "Set a class for this icon."
+      type: "string"
+      default: ""
+  template: >
+    <svg
+      {{ attributes
+          .setAttribute('viewBox', attributes.viewBox|default('0 0 24 24'))
+          .setAttribute('class', class)
+          .setAttribute('width', size|default('20'))
+          .setAttribute('height', size|default('20'))
+          .setAttribute('aria-hidden', 'true')
+      }}
+    >
+      {{ content }}
+    </svg>
diff --git a/admin_toolbar_tools/admin_toolbar_tools.module b/admin_toolbar_tools/admin_toolbar_tools.module
index 4ac3c28..45002d8 100644
--- a/admin_toolbar_tools/admin_toolbar_tools.module
+++ b/admin_toolbar_tools/admin_toolbar_tools.module
@@ -112,3 +112,14 @@ function admin_toolbar_tools_form_project_browser_settings_alter(&$form) {
 function admin_toolbar_tools_project_browser_settings_submit(&$form) {
   \Drupal::service('plugin.manager.menu.link')->rebuild();
 }
+
+/**
+ * Implements hook_preprocess_HOOK().
+ */
+function admin_toolbar_tools_preprocess_navigation_menu__admin(&$variables) {
+  if (isset($variables['items']['admin_toolbar_tools.help'])) {
+    // Add icon to the help menu item.
+    $variables['items']['admin_toolbar_tools.help']['icon']['pack_id'] = 'admin_toolbar_tools';
+    $variables['items']['admin_toolbar_tools.help']['icon']['icon_id'] = 'local_tasks';
+  }
+}
diff --git a/admin_toolbar_tools/assets/icons/local_tasks.svg b/admin_toolbar_tools/assets/icons/local_tasks.svg
new file mode 100644
index 0000000..c897197
--- /dev/null
+++ b/admin_toolbar_tools/assets/icons/local_tasks.svg
@@ -0,0 +1,3 @@
+<svg fill="#bebebe" height="24" width="24" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
+  <path d="M4 10.5c-.83 0-1.5.67-1.5 1.5s.67 1.5 1.5 1.5 1.5-.67 1.5-1.5-.67-1.5-1.5-1.5zm0-6c-.83 0-1.5.67-1.5 1.5S3.17 7.5 4 7.5 5.5 6.83 5.5 6 4.83 4.5 4 4.5zm0 12c-.83 0-1.5.68-1.5 1.5s.68 1.5 1.5 1.5 1.5-.68 1.5-1.5-.67-1.5-1.5-1.5zM7 19h14v-2H7v2zm0-6h14v-2H7v2zm0-8v2h14V5H7z"/>
+</svg>
